{
  "name": "housing-investment-api",
  "version": "1.0.0",
  "description": "Housing Investment API for Hacienda compliance",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:backup": "bash scripts/backup-db.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
